@{
    var userName = Context.Session.GetString("UserName") ?? "";
    var userRealName = Context.Session.GetString("RealName") ?? "";
    var userGender = Context.Session.GetString("Gender") ?? "男";
    var userPermissions = Context.Session.GetString("UserPermissions") ?? "";
    var userRoles = Context.Session.GetString("UserRoles") ?? "";
    var initial = userRealName.Length > 0 ? userRealName.Substring(0, 1) : "?";
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 校园干洗店管理系统</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body>
    <div id="userGender" data-gender="@userGender" style="display:none"></div>
    <div class="app-container">
        <aside class="sidebar">
            <div class="sidebar-header">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" width="32" height="32">
                    <circle cx="32" cy="32" r="30" fill="url(#grad1)" stroke="none"/>
                    <path d="M22 44 L22 28 Q22 22 32 22 Q42 22 42 28 L42 44" stroke="white" stroke-width="2.5" fill="none"/>
                    <circle cx="32" cy="30" r="4" fill="white"/>
                    <path d="M18 44 L46 44" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
                <span>干洗店管理</span>
            </div>
            <nav class="sidebar-nav">
                <a class="nav-item @(Context.Request.Path == "/Dashboard" ? "active" : "")" asp-page="/Dashboard">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    <span>首页</span>
                </a>
                @if (userRoles.Contains("admin"))
                {
                    <a class="nav-item @(Context.Request.Path == "/UserManagement" ? "active" : "")" asp-page="/UserManagement">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                        <span>用户管理</span>
                    </a>
                    <a class="nav-item @(Context.Request.Path == "/LaundryShop" ? "active" : "")" asp-page="/LaundryShop">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                        </svg>
                        <span>门店管理</span>
                    </a>
                }
                @if (userRoles.Contains("user"))
                {
                    <a class="nav-item @(Context.Request.Path == "/MyOrders" ? "active" : "")" asp-page="/MyOrders">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
                        </svg>
                        <span>我的订单</span>
                    </a>
                }
            </nav>
            <div class="sidebar-footer">
                <form asp-page="/Logout" method="post" id="logoutForm">
                    <button type="submit" class="btn-logout">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                        <span>退出登录</span>
                    </button>
                </form>
            </div>
        </aside>
        <main class="main-content">
            <header class="top-bar">
                <div class="top-bar-left">
                    <h2 class="page-title">@ViewData["Title"]</h2>
                </div>
                <div class="top-bar-right">
                    <div class="user-menu">
                        <a class="user-avatar" href="javascript:void(0);" id="userAvatarBtn" title="个人信息">
                            <div class="avatar-circle">
                                @initial
                            </div>
                            <span class="user-name">@userRealName</span>
                        </a>
                        <div class="profile-popup" id="profilePopup">
                            <div class="profile-popup-header">
                                <span>个人信息</span>
                                <button class="profile-popup-close" id="profilePopupClose">&times;</button>
                            </div>
                            <div class="profile-popup-body">
                                <form id="profileForm" method="post" action="/Personal">
                                    <div class="form-row">
                                        <label>用户名</label>
                                        <input type="text" value="@userName" readonly class="form-readonly" id="popupUsername" />
                                    </div>
                                    <div class="form-row">
                                        <label>姓名</label>
                                        <input type="text" name="RealName" value="@userRealName" class="form-input" id="popupRealName" />
                                    </div>
                                    <div class="form-row">
                                        <label>性别</label>
                                        <div class="form-radio-group">
                                            <label class="form-radio"><input type="radio" name="Gender" value="男" checked /> 男</label>
                                            <label class="form-radio"><input type="radio" name="Gender" value="女" /> 女</label>
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <label>密码</label>
                                        <input type="password" name="Password" placeholder="不修改请留空" class="form-input" id="popupPassword" />
                                    </div>
                                    <button type="submit" class="btn-popup-save">保存</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </header>
            <div class="content-area">
                @RenderBody()
            </div>
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <div id="appToast" class="app-toast" style="display:none;"></div>
    <script>
        // Profile popup toggle
        document.getElementById('userAvatarBtn').addEventListener('click', function() {
            var popup = document.getElementById('profilePopup');
            var gender = document.getElementById('userGender').getAttribute('data-gender');
            popup.style.display = popup.style.display === 'block' ? 'none' : 'block';
            // Set gender radio
            var radios = popup.querySelectorAll('input[name="Gender"]');
            radios.forEach(function(r) { r.checked = r.value === gender; });
        });
        document.getElementById('profilePopupClose').addEventListener('click', function() {
            document.getElementById('profilePopup').style.display = 'none';
        });
        document.addEventListener('click', function(e) {
            var popup = document.getElementById('profilePopup');
            var btn = document.getElementById('userAvatarBtn');
            if (!popup.contains(e.target) && e.target !== btn && !btn.contains(e.target)) {
                popup.style.display = 'none';
            }
        });
        // AJAX form submit
        document.getElementById('profileForm').addEventListener('submit', function(e) {
            e.preventDefault();
            var form = this;
            var formData = new FormData(form);
            fetch(form.action || '/Personal', {
                method: 'POST',
                body: formData,
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            }).then(function(r) { return r.json(); }).then(function(data) {
                if (data.success) {
                    // Update avatar display
                    document.querySelector('.user-name').textContent = data.realName || '';
                    document.querySelector('.avatar-circle').textContent = data.initial || '?';
                    document.getElementById('userGender').setAttribute('data-gender', data.gender || '男');
                    // Close popup
                    document.getElementById('profilePopup').style.display = 'none';
                    // Show toast
                    showToast(data.message || '保存成功', true);
                } else {
                    showToast(data.message || '保存失败', false);
                }
            }).catch(function() {
                showToast('服务异常，请稍后重试', false);
            });
        });
        function showToast(msg, success) {
            var toast = document.getElementById('appToast');
            toast.textContent = msg;
            toast.style.display = '';
            toast.className = 'app-toast show ' + (success ? 'app-toast-success' : 'app-toast-error');
            setTimeout(function() { toast.className = 'app-toast'; }, 3000);
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
