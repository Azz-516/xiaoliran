@page
@model xiaoliran.Pages.DashboardModel
@{
    ViewData["Title"] = "首页";
    Layout = "/Pages/Shared/_AppLayout.cshtml";
}

@if (Model.IsAdmin)
{
    <div class="dashboard-grid">
        <div class="stat-card">
            <div class="stat-icon purple">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </div>
            <div class="stat-value">@Model.UserCount</div>
            <div class="stat-label">注册用户</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon blue">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                </svg>
            </div>
            <div class="stat-value">@Model.ShopCount</div>
            <div class="stat-label">洗衣门店</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
                    <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                </svg>
            </div>
            <div class="stat-value">@Model.PendingOrderCount</div>
            <div class="stat-label">待处理订单</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon teal">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
            </div>
            <div class="stat-value">@Model.ProcessedOrderCount</div>
            <div class="stat-label">已处理订单</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon orange">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
                    <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
            </div>
            <div class="stat-value">¥@Model.MonthlyRevenue.ToString("N0")</div>
            <div class="stat-label">本月营收</div>
        </div>
    </div>

    <div class="card-main">
        <div class="card-main-header">
            <h3>最近订单</h3>
        </div>
        <div class="card-main-body">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>订单号</th>
                        <th>用户</th>
                        <th>衣物类型</th>
                        <th>门店</th>
                        <th>状态</th>
                        <th>下单时间</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentOrders.Count == 0)
                    {
                        <tr><td colspan="6" style="text-align:center;color:#a0aec0;">暂无订单数据</td></tr>
                    }
                    else
                    {
                        @foreach (var order in Model.RecentOrders)
                        {
                            <tr>
                                <td>@order.OrderNo</td>
                                <td>@order.UserName</td>
                                <td>@order.ClothingType</td>
                                <td>@order.ShopName</td>
                                <td><span class="badge-status @(GetOrderBadgeClass(order.Status))">@order.Status</span></td>
                                <td>@order.CreateTime</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card-main">
        <div class="card-main-header">
            <h3>门店列表</h3>
            <form method="get" style="display:flex;gap:8px;align-items:center;">
                <input type="text" name="searchKey" value="@Model.SearchKey" placeholder="搜索门店名称或地址" class="form-input" style="width:180px;" />
                <select name="statusFilter" class="form-input" style="width:100px;">
                    <option value="">全部状态</option>
                    @if (Model.StatusFilter == "营业中")
                    {
                        <option value="营业中" selected>营业中</option>
                        <option value="已停业">已停业</option>
                    }
                    else if (Model.StatusFilter == "已停业")
                    {
                        <option value="营业中">营业中</option>
                        <option value="已停业" selected>已停业</option>
                    }
                    else
                    {
                        <option value="营业中">营业中</option>
                        <option value="已停业">已停业</option>
                    }
                </select>
                <button type="submit" class="btn-primary-app">搜索</button>
            </form>
        </div>
        <div class="card-main-body">
            <div class="shop-grid">
                @foreach (var shop in Model.Shops)
                {
                    <div class="shop-card @(shop.Status == "已停业" ? "shop-closed" : "")">
                        <div class="shop-card-header">
                            <h3>@shop.Name</h3>
                            <span class="shop-status-badge @(shop.Status == "营业中" ? "status-open" : "status-closed")">@shop.Status</span>
                        </div>
                        <div class="shop-card-body">
                            <div class="shop-info-row">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                                </svg>
                                <span>@shop.Address</span>
                            </div>
                            <div class="shop-info-row">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                                </svg>
                                <span>@shop.ContactPhone</span>
                            </div>
                            @if (!string.IsNullOrEmpty(shop.BusinessHours))
                            {
                                <div class="shop-info-row">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
                                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                                    </svg>
                                    <span>@shop.BusinessHours</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(shop.Description))
                            {
                                <div class="shop-description">@shop.Description</div>
                            }
                        </div>
                        <div class="shop-card-footer">
                            <button class="btn-shop-action" onclick="showOrderModal(@shop.Id, '@shop.Name.Replace("'", "\\'")')">立即下单</button>
                        </div>
                    </div>
                }
            </div>
        </div>
        @if (Model.TotalPages > 1)
        {
            <div class="card-main-footer">
                <div class="pagination">
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <a class="page-link @(i == Model.CurrentPage ? "active" : "")"
                           asp-page="/Dashboard"
                           asp-route-p="@i"
                           asp-route-searchKey="@Model.SearchKey"
                           asp-route-statusFilter="@Model.StatusFilter">@i</a>
                    }
                </div>
            </div>
        }
    </div>
}

<!-- Order Modal -->
<div class="modal-overlay" id="orderModal">
    <div class="modal-content" style="max-width:560px;">
        <h3>下单</h3>
        <form id="orderForm">
            <input type="hidden" name="LaundryShopId" id="orderShopId" />
            <div class="form-row">
                <label>洗衣店</label>
                <input type="text" id="orderShopName" class="form-readonly" readonly />
            </div>
            <div class="form-row">
                <label>服务类型</label>
                <select name="ServiceType" id="orderServiceType" class="form-input">
                    <option value="洗衣">洗衣</option>
                    <option value="干洗">干洗</option>
                    <option value="熨烫">熨烫</option>
                    <option value="洗鞋">洗鞋</option>
                </select>
            </div>
            <div class="form-row">
                <label>衣物类型</label>
                <select name="ClothingType" id="orderClothingType" class="form-input">
                    <option value="T恤/衬衫">T恤/衬衫</option>
                    <option value="裤子">裤子</option>
                    <option value="外套">外套</option>
                    <option value="鞋子">鞋子</option>
                    <option value="其他">其他</option>
                </select>
            </div>
            <div class="form-row">
                <label>数量</label>
                <select name="Quantity" id="orderQuantity" class="form-input">
                    @for (var i = 1; i <= 10; i++) { <option value="@i">@i 件</option> }
                </select>
            </div>
            <div class="form-row">
                <label>预估费用</label>
                <div id="orderEstimatedCost" class="order-cost-display">¥0.00</div>
                <input type="hidden" name="EstimatedCost" id="orderEstimatedCostInput" />
            </div>
            <div class="form-row" id="orderUnsupportedNotice" style="display:none;">
                <div class="order-unsupported-msg">此服务不支持此类衣物</div>
            </div>
            <div class="form-row">
                <label>取件时间</label>
                <input type="datetime-local" name="PickupTime" class="form-input" />
            </div>
            <div class="form-row">
                <label>备注</label>
                <textarea name="Remark" class="form-input" rows="2" placeholder="选填"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secondary-app" onclick="closeOrderModal()">取消</button>
                <button type="submit" class="btn-primary-app">确认下单</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    var PRICING = {
        '洗衣':  { 'T恤/衬衫': 15, '裤子': 15, '外套': 20, '鞋子': null, '其他': 18 },
        '干洗':  { 'T恤/衬衫': 25, '裤子': 25, '外套': 35, '鞋子': null, '其他': 30 },
        '熨烫':  { 'T恤/衬衫': 12, '裤子': 12, '外套': 18, '鞋子': null, '其他': 15 },
        '洗鞋':  { 'T恤/衬衫': null, '裤子': null, '外套': null, '鞋子': 20, '其他': 25 }
    };

    var reloadTimer = null;

    function calcEstimatedCost() {
        var service = document.getElementById('orderServiceType').value;
        var clothing = document.getElementById('orderClothingType').value;
        var qty = parseInt(document.getElementById('orderQuantity').value) || 1;
        var unit = PRICING[service]?.[clothing];
        var costEl = document.getElementById('orderEstimatedCost');
        var noticeEl = document.getElementById('orderUnsupportedNotice');
        var submitBtn = document.querySelector('#orderForm .btn-primary-app');

        if (!unit) {
            costEl.textContent = '—';
            costEl.classList.add('order-cost-unsupported');
            noticeEl.style.display = '';
            submitBtn.disabled = true;
            submitBtn.style.opacity = '0.5';
            document.getElementById('orderEstimatedCostInput').value = '';
            return;
        }

        var total = unit * qty;
        costEl.textContent = '¥' + total.toFixed(2);
        costEl.classList.remove('order-cost-unsupported');
        noticeEl.style.display = 'none';
        submitBtn.disabled = false;
        submitBtn.style.opacity = '1';
        document.getElementById('orderEstimatedCostInput').value = total;
    }

    function showOrderModal(shopId, shopName) {
        if (reloadTimer) { clearTimeout(reloadTimer); reloadTimer = null; }
        document.getElementById('orderForm').reset();
        document.getElementById('orderShopId').value = shopId;
        document.getElementById('orderShopName').value = shopName;
        document.getElementById('orderQuantity').value = '1';
        calcEstimatedCost();
        document.getElementById('orderModal').classList.add('show');
    }

    document.getElementById('orderServiceType').addEventListener('change', calcEstimatedCost);
    document.getElementById('orderClothingType').addEventListener('change', calcEstimatedCost);
    document.getElementById('orderQuantity').addEventListener('change', calcEstimatedCost);
    function closeOrderModal() {
        document.getElementById('orderModal').classList.remove('show');
        document.getElementById('orderForm').reset();
    }
    document.getElementById('orderForm').addEventListener('submit', function(e) {
        e.preventDefault();
        var fd = new FormData(this);
        fetch('?handler=AddOrder', { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function(r) { return r.json(); }).then(function(data) {
                showToast(data.success ? (data.message || '下单成功') : data.message, data.success);
                if (data.success) { closeOrderModal(); reloadTimer = setTimeout(function() { location.reload(); }, 1500); }
            });
    });
    document.getElementById('orderModal').addEventListener('click', function(e) { if (e.target === this) closeOrderModal(); });
</script>
@if (!string.IsNullOrEmpty(Model.ToastMessage))
{
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            showToast('@Model.ToastMessage', false);
        });
    </script>
}
}


@functions {
    public static string GetOrderBadgeClass(string status)
    {
        return status switch
        {
            "待取件" => "pending",
            "待清洗" => "washing",
            "洗涤中" => "washing",
            "已完成" => "done",
            "已送达" => "delivered",
            _ => "pending"
        };
    }
}
