@page
@model xiaoliran.Pages.ClothingModel
@{
    ViewData["Title"] = "衣服管理";
    Layout = "/Pages/Shared/_AppLayout.cshtml";
}

<div class="dashboard-grid">
    <div class="stat-card">
        <div class="stat-icon purple">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
                <path d="M20.38 3.46L16 2 12 3.46 8 2 3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"/>
            </svg>
        </div>
        <div class="stat-value">856</div>
        <div class="stat-label">衣物总数</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
        </div>
        <div class="stat-value">234</div>
        <div class="stat-label">洗涤中</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
        </div>
        <div class="stat-value">622</div>
        <div class="stat-label">已完成</div>
    </div>
</div>

<div class="card-main">
    <div class="card-main-header">
        <h3>衣物记录</h3>
    </div>
    <div class="card-main-body">
        <table class="data-table">
            <thead>
                <tr>
                    <th>编号</th>
                    <th>衣物类型</th>
                    <th>洗涤方式</th>
                    <th>价格</th>
                    <th>状态</th>
                    <th>登记时间</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>#CL-001</td>
                    <td>西装上衣</td>
                    <td>干洗</td>
                    <td>¥35</td>
                    <td><span class="badge-status pending">待取件</span></td>
                    <td>2026-05-13 09:00</td>
                </tr>
                <tr>
                    <td>#CL-002</td>
                    <td>羽绒服</td>
                    <td>水洗</td>
                    <td>¥45</td>
                    <td><span class="badge-status washing">洗涤中</span></td>
                    <td>2026-05-13 09:30</td>
                </tr>
                <tr>
                    <td>#CL-003</td>
                    <td>衬衫</td>
                    <td>熨烫</td>
                    <td>¥15</td>
                    <td><span class="badge-status done">已完成</span></td>
                    <td>2026-05-12 14:00</td>
                </tr>
                <tr>
                    <td>#CL-004</td>
                    <td>运动鞋</td>
                    <td>精洗</td>
                    <td>¥58</td>
                    <td><span class="badge-status done">已完成</span></td>
                    <td>2026-05-12 11:20</td>
                </tr>
                <tr>
                    <td>#CL-005</td>
                    <td>羊绒大衣</td>
                    <td>干洗</td>
                    <td>¥68</td>
                    <td><span class="badge-status delivered">已送达</span></td>
                    <td>2026-05-11 16:30</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
